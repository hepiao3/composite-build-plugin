<idea-plugin>
    <id>com.jdme.composite-build-manager</id>
    <name>Composite Build Manager</name>
    <vendor>JDME</vendor>
    <description><![CDATA[
        <img src="https://coding.jd.com/jme/composite-build-plugin/raw/master/screenshots/preview.png" width="600"/><br/><br/>
        管理 Android 多模块复合构建（Composite Build）配置。<br/>
        通过侧边面板可视化管理所有子模块的构建模式，支持一键切换 includeBuild 并自动触发 Gradle Sync。<br/><br/>
        功能：
        <ul>
          <li>可视化展示所有子模块的 LOCAL / MAVEN / MISSING 状态</li>
          <li>一键切换 includeBuild 模式（自动生成/修改 include_build.gradle）</li>
          <li>支持一键下载缺失模块（委托 Node.js 脚本或 git clone）</li>
          <li>集成 Gradle Sync 触发，有未同步改动时按钮高亮提醒</li>
          <li>显示各模块当前 Git 分支，支持一键切换（含未提交修改检查）</li>
          <li>支持组件名搜索过滤</li>
        </ul>
    ]]></description>

    <!-- 兼容 Android Studio Hedgehog (2023.3.1) 及以上，无版本上限 -->
    <idea-version since-build="233"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.gradle</depends>
    <depends>org.jetbrains.android</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Gutter Icon：在 .gradle 依赖行左侧显示「+」按钮，触发 CBM 复合构建配置 -->
        <codeInsight.lineMarkerProvider
            language="Groovy"
            implementationClass="com.jdme.cbm.actions.CbmLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
            language="kotlin"
            implementationClass="com.jdme.cbm.actions.CbmLineMarkerProvider"/>

        <!-- Tool Window：侧边面板 -->
        <toolWindow
            id="Composite Build"
            displayName="Composite Build"
            factoryClass="com.jdme.cbm.ui.CompositeBuildToolWindow"
            anchor="right"
            icon="/icons/composite_build.svg"
            defaultWidth="300"
        />

        <!-- 持久化：记住用户手动指定的配置文件路径 -->
        <applicationService
            serviceImplementation="com.jdme.cbm.core.CbmSettings"
        />

        <!-- 项目级服务：业务逻辑协调层 -->
        <projectService
            serviceImplementation="com.jdme.cbm.core.CbmProjectService"
        />

        <!-- 项目级设置：用户自定义配置文件路径 -->
        <projectService
            serviceImplementation="com.jdme.cbm.core.CbmProjectSettings"
        />

        <!-- Settings > Tools > Composite Build Manager -->
        <projectConfigurable
            parentId="tools"
            instance="com.jdme.cbm.ui.CbmProjectConfigurable"
            id="com.jdme.cbm.CbmProjectConfigurable"
            displayName="Composite Build Manager"
        />
    </extensions>

    <resource-bundle>messages.CbmBundle</resource-bundle>

    <actions>
        <!-- 右键菜单：切换构建模式 -->
        <group
            id="com.jdme.cbm.CompositeBuildMenu"
            text="Composite Build"
            popup="true">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>

            <action
                id="com.jdme.cbm.SwitchBuildMode"
                class="com.jdme.cbm.actions.SwitchBuildModeAction"
                text="%action.switch_build_mode.text%"
                description="%action.switch_build_mode.description%"
            />

            <action
                id="com.jdme.cbm.SyncGradle"
                class="com.jdme.cbm.actions.SyncGradleAction"
                text="Sync Gradle Now"
                description="%action.sync_gradle.description%"
            />
        </group>
    </actions>
</idea-plugin>
